# Google Maps — client-side key (restrict by HTTP referrer to *.vercel.app + custom domain)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Google Maps — server-side key (used in API routes only, never exposed to client)
GOOGLE_MAPS_SERVER_KEY=

# Supabase — public URL and anon key (safe to expose; RLS enforced)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — service role key (server-side only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# PostHog — event tracking
NEXT_PUBLIC_POSTHOG_KEY=

# Sentry
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
